{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 28,
        "patch": 3
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "dev-linux",
            "displayName": "Linux Development",
            "inherits": "base",
            "binaryDir": "${sourceDir}/build/dev-linux",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "Mapper_DEVELOPMENT_BUILD": "ON"
            }
        },
        {
            "name": "dev-macos",
            "displayName": "macOS Development",
            "inherits": "base",
            "binaryDir": "${sourceDir}/build/dev-macos",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "Mapper_DEVELOPMENT_BUILD": "ON"
            }
        },
        {
            "name": "dev-windows",
            "displayName": "Windows Development (MSYS2 MINGW64)",
            "inherits": "base",
            "binaryDir": "${sourceDir}/build/dev-windows",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "Mapper_DEVELOPMENT_BUILD": "ON"
            }
        },
        {
            "name": "ci-base",
            "hidden": true,
            "inherits": "base",
            "cacheVariables": {
                "Mapper_DEVELOPMENT_BUILD": "OFF",
                "Mapper_USE_GDAL": "ON",
                "Mapper_PACKAGE_QT": "OFF",
                "Mapper_PACKAGE_PROJ": "OFF",
                "Mapper_PACKAGE_GDAL": "OFF",
                "Mapper_PACKAGE_ASSISTANT": "OFF",
                "Mapper_MANUAL_QTHELP": "OFF"
            }
        },
        {
            "name": "ci-linux",
            "displayName": "Linux CI",
            "inherits": "ci-base",
            "binaryDir": "${sourceDir}/build/ci-linux",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        },
        {
            "name": "ci-macos",
            "displayName": "macOS CI",
            "inherits": "ci-base",
            "binaryDir": "${sourceDir}/build/ci-macos",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "ci-windows",
            "displayName": "Windows CI (MSYS2 MINGW64)",
            "inherits": "ci-base",
            "binaryDir": "${sourceDir}/build/ci-windows",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "release-linux",
            "displayName": "Linux Release",
            "inherits": "ci-linux",
            "binaryDir": "${sourceDir}/build/release-linux",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "Mapper_MANUAL_QTHELP": "ON"
            }
        },
        {
            "name": "release-macos",
            "displayName": "macOS Release",
            "inherits": "ci-macos",
            "binaryDir": "${sourceDir}/build/release-macos",
            "cacheVariables": {
                "Mapper_PACKAGE_QT": "ON",
                "Mapper_PACKAGE_PROJ": "ON",
                "Mapper_PACKAGE_GDAL": "ON",
                "Mapper_MANUAL_QTHELP": "ON"
            }
        },
        {
            "name": "release-windows",
            "displayName": "Windows Release (MSYS2 MINGW64)",
            "inherits": "ci-windows",
            "binaryDir": "${sourceDir}/build/release-windows",
            "cacheVariables": {
                "Mapper_PACKAGE_QT": "ON",
                "Mapper_PACKAGE_PROJ": "ON",
                "Mapper_PACKAGE_GDAL": "ON",
                "Mapper_MANUAL_QTHELP": "ON",
                "GDAL_DATA_DIR": "/mingw64/share/gdal",
                "PROJ_DATA_DIR": "/mingw64/share/proj"
            }
        },
        {
            "name": "mobile-base",
            "hidden": true,
            "inherits": "ci-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_SHARED_LIBS": "OFF",
                "Mapper_PACKAGE_ASSISTANT": "OFF"
            }
        },
        {
            "name": "android-arm64",
            "displayName": "Android arm64-v8a",
            "inherits": "mobile-base",
            "binaryDir": "${sourceDir}/build/android-arm64",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "$env{ANDROID_NDK_ROOT}/build/cmake/android.toolchain.cmake",
                "ANDROID_ABI": "arm64-v8a",
                "ANDROID_PLATFORM": "android-28",
                "QT_HOST_PATH": "$env{QT_HOST_PATH}"
            }
        },
        {
            "name": "android-x86_64",
            "displayName": "Android x86_64 (emulator)",
            "inherits": "mobile-base",
            "binaryDir": "${sourceDir}/build/android-x86_64",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "$env{ANDROID_NDK_ROOT}/build/cmake/android.toolchain.cmake",
                "ANDROID_ABI": "x86_64",
                "ANDROID_PLATFORM": "android-28",
                "QT_HOST_PATH": "$env{QT_HOST_PATH}"
            }
        },
        {
            "name": "ios-arm64",
            "displayName": "iOS arm64",
            "inherits": "mobile-base",
            "generator": "Xcode",
            "binaryDir": "${sourceDir}/build/ios-arm64",
            "cacheVariables": {
                "CMAKE_SYSTEM_NAME": "iOS",
                "CMAKE_OSX_DEPLOYMENT_TARGET": "16.0",
                "CMAKE_OSX_ARCHITECTURES": "arm64"
            }
        },
        {
            "name": "ios-simulator",
            "displayName": "iOS Simulator (arm64)",
            "inherits": "mobile-base",
            "generator": "Xcode",
            "binaryDir": "${sourceDir}/build/ios-simulator",
            "cacheVariables": {
                "CMAKE_SYSTEM_NAME": "iOS",
                "CMAKE_OSX_DEPLOYMENT_TARGET": "16.0",
                "CMAKE_OSX_ARCHITECTURES": "arm64",
                "CMAKE_OSX_SYSROOT": "iphonesimulator"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "dev-linux",
            "configurePreset": "dev-linux"
        },
        {
            "name": "dev-macos",
            "configurePreset": "dev-macos"
        },
        {
            "name": "dev-windows",
            "configurePreset": "dev-windows"
        },
        {
            "name": "ci-linux",
            "configurePreset": "ci-linux"
        },
        {
            "name": "ci-macos",
            "configurePreset": "ci-macos"
        },
        {
            "name": "ci-windows",
            "configurePreset": "ci-windows"
        },
        {
            "name": "release-linux",
            "configurePreset": "release-linux"
        },
        {
            "name": "release-macos",
            "configurePreset": "release-macos"
        },
        {
            "name": "release-windows",
            "configurePreset": "release-windows"
        },
        {
            "name": "android-arm64",
            "configurePreset": "android-arm64"
        },
        {
            "name": "android-x86_64",
            "configurePreset": "android-x86_64"
        },
        {
            "name": "ios-arm64",
            "configurePreset": "ios-arm64"
        },
        {
            "name": "ios-simulator",
            "configurePreset": "ios-simulator"
        }
    ],
    "testPresets": [
        {
            "name": "dev-linux",
            "configurePreset": "dev-linux",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "dev-macos",
            "configurePreset": "dev-macos",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "dev-windows",
            "configurePreset": "dev-windows",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "ci-linux",
            "configurePreset": "ci-linux",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "ci-macos",
            "configurePreset": "ci-macos",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "ci-windows",
            "configurePreset": "ci-windows",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "release-linux",
            "configurePreset": "release-linux",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "release-macos",
            "configurePreset": "release-macos",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "release-windows",
            "configurePreset": "release-windows",
            "output": { "outputOnFailure": true }
        }
    ]
}
