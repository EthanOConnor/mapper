<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Mapper Rust dependency licenses</title>
  <style>
    body { font-family: sans-serif; margin: 2rem auto; max-width: 70rem; padding: 0 1rem; }
    pre { overflow-wrap: anywhere; white-space: pre-wrap; }
  </style>
</head>
<body>
<h1>Mapper Rust dependency licenses</h1>
<p>This inventory is generated from the exact locked dependency graph.</p>
{{#each licenses}}
<section>
  <h2 id="{{id}}">{{name}}</h2>
  <p>Used by:</p>
  <ul>
  {{#each used_by}}
    <li><a href="{{#if crate.repository}}{{crate.repository}}{{else}}https://crates.io/crates/{{crate.name}}{{/if}}">{{crate.name}} {{crate.version}}</a></li>
  {{/each}}
  </ul>
  <pre>{{text}}</pre>
</section>
{{/each}}
</body>
</html>
