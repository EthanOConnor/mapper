# Leak suppressions: set LSAN_OPTIONS=suppressions=<path>/suppress.txt
# UBSan suppressions: set UBSAN_OPTIONS=suppressions=<path>/suppress.txt
#
# ASan enables leak detection via detect_leaks=1 in ASAN_OPTIONS, but
# leak suppressions are read from LSAN_OPTIONS, not ASAN_OPTIONS.
#
# Cf. https://github.com/google/sanitizers/wiki/AddressSanitizerLeakSanitizer
# Cf. https://clang.llvm.org/docs/UndefinedBehaviorSanitizer.html

# Qt 6 known issues
leak:libfontconfig
leak:libQt6Gui
leak:libxcb
leak:QArrayData::allocate
leak:QObject
leak:XIQueryDevice

# Qt vptr issue (tools_t)
vptr:QMouseEvent
